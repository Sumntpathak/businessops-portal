# Neon PostgreSQL
DATABASE_URL=

# JWT secret
JWT_SECRET=

# Mock payment webhook secret
MOCK_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set true when new self-registered accounts need admin activation
REQUIRE_ADMIN_ACTIVATION=false

# SMTP — used for password-reset emails
# Demo yopmail accounts ALWAYS use these env-var credentials.
# Non-yopmail users use the admin-configured integration (Settings → Integrations)
# with these env vars as a fallback.
#
# Gmail example (create an App Password at myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM="BusinessOps <you@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Seed user passwords (required only when running npm run db:seed)
SEED_ADMIN_PASSWORD=
SEED_MANAGER_PASSWORD=
SEED_AGENT_ONE_PASSWORD=
SEED_AGENT_TWO_PASSWORD=
SEED_FINANCE_PASSWORD=
